<?xml version="1.0"?>
<phpunit
	bootstrap="tests/bootstrap.php"
	colors="true"
	convertErrorsToExceptions="true"
	convertNoticesToExceptions="true"
	convertWarningsToExceptions="true"
	failOnWarning="true">
	<testsuites>
		<testsuite name="unit">
			<directory suffix="-test.php">./tests</directory>
		</testsuite>
	</testsuites>
</phpunit>
